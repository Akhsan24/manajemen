{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "components/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/materi/(.*)",
      "dest": "/materi/$1"
    },
    {
      "src": "/artikel/(.*)",
      "dest": "/artikel/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}